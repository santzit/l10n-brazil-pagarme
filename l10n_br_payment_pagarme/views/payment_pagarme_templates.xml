<?xml version="1.0" encoding="utf-8" ?>
<odoo>
  <template id="inline_form">
    <div t-attf-id="pagarme-container-{{provider_id}}">
      <div class="row">
        <div class="mb-3">
          <input name="provider_id" type="hidden" id="provider_id" t-att-value="id" />
          <input name="partner_id" type="hidden" t-att-value="partner_id" />
        </div>

        <!-- Card Number -->
        <div class="col-12 col-md-6 mt-0 mb-3">
          <label for="customer_input" class="form-label">
            <small>
              <b>Card Number</b>
            </small>
          </label>
          <input
            type="text"
            name="customer_input"
            id="customer_input"
            class="form-control"
            placeholder="XXXX XXXX XXXX XXXX"
            maxlength="19"
          />
        </div>

        <!-- Card Holder Name -->
        <div class="col-12 col-md-6 mt-0 mb-3">
          <label for="card_holder_name" class="form-label">
            <small>
              <b>Card Holder Name</b>
            </small>
          </label>
          <input
            type="text"
            name="card_holder_name"
            id="card_holder_name"
            class="form-control"
            placeholder="Name as shown on card"
            t-att-value="partner_name"
          />
        </div>

        <!-- CPF/CNPJ -->
        <div class="col-12 col-md-6 mt-0 mb-3">
          <label for="cardholder_document" class="form-label">
            <small>
              <b>CPF/CNPJ</b>
            </small>
          </label>
          <input
            type="text"
            name="cardholder_document"
            id="cardholder_document"
            class="form-control"
            placeholder="000.000.000-00 or 00.000.000/0000-00"
          />
        </div>

        <!-- Expiration Date -->
        <div class="col-6 col-md-3 mt-0 mb-3">
          <label for="card_expiry" class="form-label">
            <small>
              <b>Expiry Date</b>
            </small>
          </label>
          <input
            type="text"
            name="card_expiry"
            id="card_expiry"
            class="form-control"
            placeholder="MM/AA"
            maxlength="5"
          />
        </div>

        <!-- CVV -->
        <div class="col-6 col-md-3 mt-0 mb-3">
          <label for="card_cvv" class="form-label">
            <small>
              <b>CVV</b>
            </small>
          </label>
          <input
            type="text"
            name="card_cvv"
            id="card_cvv"
            class="form-control"
            placeholder="123"
            maxlength="4"
          />
        </div>

        <!-- Payment Status -->
        <div class="col-12 col-md-6 mt-0 mb-3">
          <label for="simulated_payment_state" class="form-label">
            <small>
              <b>Payment Status</b>
            </small>
          </label>
          <select id="simulated_payment_state" class="form-select">
            <option value="done" title="Successful payment">
                            Successful
                        </option>
            <option value="pending" title="Payment processing">
                            Pending
                        </option>
            <option value="cancel" title="Payment canceled by customer">
                            Canceled
                        </option>
            <option value="error" title="Processing error">
                            Error
                        </option>
          </select>
        </div>
      </div>
    </div>
  </template>

  <template id="token_inline_form">
    <div t-attf-id="pagarme-token-container-{{token.id}}">
      <div class="alert alert-warning m-2">
        <span t-if="token.pagarme_simulated_state=='pending'">
                    Payments made with this payment method will remain <b>pending</b>.
                </span>
        <span t-elif="token.pagarme_simulated_state=='done'">
                    Payments made with this payment method will be <b>successful</b>.
                </span>
        <span t-elif="token.pagarme_simulated_state=='cancel'">
                    Payments made with this payment method will be automatically <b
          >canceled</b>.
                </span>
        <span t-else="">
                    Payments made with this payment method will simulate a processing <b
          >error</b>.
                </span>
      </div>
    </div>
  </template>
</odoo>
