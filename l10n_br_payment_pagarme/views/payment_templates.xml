<?xml version="1.0" encoding="utf-8" ?>
<odoo>
  <template
    id="verified_token_checkmark"
    inherit_id="payment.verified_token_checkmark"
    priority="99"
  >
    <xpath expr="." position="inside">
      <t t-if="token.provider_code == 'pagarme'">
        <span class="badge rounded-pill text-bg-warning ms-1">Pagarme Token</span>
      </t>
    </xpath>
  </template>
</odoo>
