<?xml version="1.0" encoding="utf-8" ?>
<odoo>
  <record id="payment_transaction_form" model="ir.ui.view">
    <field name="name">Pagarme Transaction Form</field>
    <field name="model">payment.transaction</field>
    <field name="inherit_id" ref="payment.payment_transaction_form" />
    <field name="arch" type="xml">
      <header position="inside">
        <field name="capture_manually" invisible="1" />
        <!-- PagarMe transactions are processed through real API calls -->
        <!-- No manual state change buttons needed as state comes from API webhooks -->
      </header>
    </field>
  </record>
</odoo>
