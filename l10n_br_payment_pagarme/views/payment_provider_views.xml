<?xml version="1.0" encoding="utf-8" ?>
<odoo>
  <record id="payment_provider_form" model="ir.ui.view">
    <field name="name">Payment Provider Form (PagarMe)</field>
    <field name="model">payment.provider</field>
    <field name="inherit_id" ref="payment.payment_provider_form" />
    <field name="arch" type="xml">
      <group name="provider_credentials" position="inside">
        <group
          attrs="{'invisible': [('code', '!=', 'pagarme')]}"
          name="pagarme_credentials"
        >
          <field
            name="pagarme_public_key"
            attrs="{'required':[('code', '=', 'pagarme'), ('state', '!=', 'disabled')]}"
          />
          <field
            name="pagarme_secret_key"
            attrs="{'required':[('code', '=', 'pagarme'), ('state', '!=', 'disabled')]}"
            password="True"
          />
          <field
            name="pagarme_use_orders_api"
            attrs="{'invisible': [('code', '!=', 'pagarme')]}"
          />
          <div
            colspan="2"
            attrs="{'invisible': [('code', '!=', 'pagarme')]}"
            class="oe_button_box"
          >
            <button
              name="action_test_pagarme_connection"
              type="object"
              string="Test Connection"
              class="btn btn-secondary"
              icon="fa-plug"
              attrs="{'invisible': [('pagarme_secret_key', '=', False)]}"
            />
          </div>
        </group>
      </group>
    </field>
  </record>
</odoo>
